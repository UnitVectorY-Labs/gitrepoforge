{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "config",
    "default_branch",
    "name"
  ],
  "properties": {
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language"
      ],
      "properties": {
        "justfile": {
          "type": "boolean",
          "default": false
        },
        "language": {
          "type": "string",
          "enum": [
            "go",
            "java"
          ]
        }
      }
    },
    "default_branch": {
      "type": "string",
      "description": "The default branch of the repository."
    },
    "name": {
      "type": "string",
      "description": "Must match the repository folder name."
    }
  }
}
