{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "default_branch",
    "name"
  ],
  "properties": {
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "readme": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "default_branch": {
      "type": "string",
      "description": "The default branch of the repository."
    },
    "name": {
      "type": "string",
      "description": "Must match the repository folder name."
    }
  }
}
